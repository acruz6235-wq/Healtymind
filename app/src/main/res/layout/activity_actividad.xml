<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/cuadrado"
        android:layout_width="125dp"
        android:layout_height="201dp"
        android:layout_marginBottom="70dp"
        android:background="@drawable/custom_shape"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.779"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.867" />

    <TextView
        android:id="@+id/Cuestioanrios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/cuestionarios"
        android:textColor="@color/purple"
        app:layout_constraintEnd_toEndOf="@+id/cuadrado"
        app:layout_constraintStart_toStartOf="@+id/cuadrado"
        app:layout_constraintTop_toTopOf="@+id/cuadrado" />

    <TextView
        android:id="@+id/Desafios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="@string/desafios"
        android:textColor="@color/purple"
        app:layout_constraintEnd_toEndOf="@+id/cuadrado"
        app:layout_constraintStart_toStartOf="@+id/cuadrado"
        app:layout_constraintTop_toBottomOf="@+id/Cuestioanrios" />

    <TextView
        android:id="@+id/Racha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="@string/racha"
        android:textColor="@color/purple"
        app:layout_constraintEnd_toEndOf="@+id/cuadrado"
        app:layout_constraintStart_toStartOf="@+id/cuadrado"
        app:layout_constraintTop_toBottomOf="@+id/Desafios" />

    <TextView
        android:id="@+id/Repiracion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="@string/respiracion"
        android:textColor="@color/purple"
        app:layout_constraintEnd_toEndOf="@+id/cuadrado"
        app:layout_constraintStart_toStartOf="@+id/cuadrado"
        app:layout_constraintTop_toBottomOf="@+id/Racha" />

</androidx.constraintlayout.widget.ConstraintLayout>